# Public API base (browser); must include /api if your backend mounts routes at /api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Optional: FEB base URL for server-side calls only (Docker/host networking). Falls back to NEXT_PUBLIC_API_URL.
# Use 127.0.0.1 here if localhost from Node resolves differently than in the browser.
# BACKEND_API_URL=http://127.0.0.1:3000/api

# finnep-ops-service BFF (server-only — never use NEXT_PUBLIC_* for secrets)
# Browser calls THIS CMS at /api/ops/...; Next proxies to OPS_SERVICE_URL with the key below.
OPS_SERVICE_URL=http://127.0.0.1:3099
OPS_AUTH_HEADER=X-Ops-Key
OPS_AUTH_SECRET=change-me-same-as-ops-service

# finnep-accounting-service BFF (server-only)
ACCOUNTING_SERVICE_URL=http://127.0.0.1:3010
ACCOUNTING_AUTH_HEADER=X-Accounting-Key
ACCOUNTING_AUTH_SECRET=change-me-same-as-accounting-service

# Optional: server-side FEB URL for accounting session validation (falls back to NEXT_PUBLIC_API_URL)
# BACKEND_API_URL=http://127.0.0.1:3001/api

# If finnep-ops-service sets OPS_STATIC_USER_HEADER / OPS_STATIC_USER, set the same here so the BFF can forward them.
# OPS_STATIC_USER_HEADER=X-Ops-User
# OPS_STATIC_USER=ops
